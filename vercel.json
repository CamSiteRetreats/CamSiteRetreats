{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "destination": "/admin",
      "permanent": false
    },
    {
      "source": "/:path((?!admin(?:/.*)?$|api(?:/.*)?$).*)",
      "destination": "/admin",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin/"
    },
    {
      "source": "/admin/assets/:path*",
      "destination": "/admin/assets/:path*"
    },
    {
      "source": "/admin/manifest.json",
      "destination": "/admin/manifest.json"
    },
    {
      "source": "/admin/icon-512.png",
      "destination": "/admin/icon-512.png"
    },
    {
      "source": "/admin/sw.js",
      "destination": "/admin/sw.js"
    },
    {
      "source": "/admin/vite.svg",
      "destination": "/admin/vite.svg"
    },
    {
      "source": "/tour/thacliengai",
      "destination": "/tour"
    },
    {
      "source": "/tour/thacliengai.html",
      "destination": "/tour"
    },
    {
      "source": "/thacliengai/:path*",
      "destination": "/tour"
    },
    {
      "source": "/pay/:id",
      "destination": "/pay?id=:id"
    },
    {
      "source": "/api/sepay-webhook",
      "destination": "/api/payment?action=webhook"
    },
    {
      "source": "/photo/:slug",
      "destination": "/api/media?slug=:slug"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin/"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version"
        }
      ]
    }
  ]
}
